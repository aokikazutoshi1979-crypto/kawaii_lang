    "scene": "trial",
    "subScene": "phrases",
    "level": "beginner",
    "tags": [
      "phrases"
    ],
    "translations": {
      "ja": "これはどういう意味ですか？",
      "en": "What does this mean?",
      "zh": "这是什么意思？",
      "zh_TW": "這是什麼意思？",
      "ko": "이건 무슨 뜻인가요?",
