    "scene": "trial",
    "subScene": "greeting",
    "level": "beginner",
    "tags": [
      "greeting"
    ],
    "translations": {
      "ja": "お元気ですか？",
      "en": "How have you been?",
      "zh": "最近怎么样？",
      "zh_TW": "最近好嗎？",
      "ko": "그동안 잘 지내셨어요?",
      "es": "¿Cómo has estado?",
      "fr": "Comment allez-vous ces jours-ci ?",
      "de": "Wie ist es dir in letzter Zeit ergangen?",
      "vi": "Dạo này bạn thế nào?",
      "id": "Apa kabar akhir-akhir ini?"
    }
  },
  {
