      "en": "Exactly!",
      "zh": "正是如此。",
      "zh_TW": "正是如此！",
      "ko": "정확해요!",
      "es": "¡Exactamente!",
      "fr": "Exactement !",
      "de": "Genau!",
      "vi": "Chính xác!",
      "id": "Tepat sekali!"
    }
  },
  {
