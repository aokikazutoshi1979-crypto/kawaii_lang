    "scene": "trial",
    "subScene": "greeting",
    "level": "intermediate",
    "tags": [
      "greeting"
    ],
    "translations": {
      "ja": "お久しぶりです。",
      "en": "Long time no see.",
      "zh": "好久不见。",
      "zh_TW": "好久不見。",
      "ko": "오랜만이에요.",
      "es": "¡Cuánto tiempo sin verte!",
      "fr": "Ça fait longtemps !",
      "de": "Lange nicht gesehen!",
      "vi": "Lâu rồi không gặp.",
      "id": "Sudah lama tidak bertemu."
    }
  },
  {
    "id": "trial_greeting_007",
    "scene": "trial",
    "subScene": "greeting",
    "level": "intermediate",
    "tags": [
      "greeting"
    ],
    "translations": {
      "ja": "よろしくお願いします。",
      "en": "I'm looking forward to working with you.",
      "zh": "请多关照。",
      "zh_TW": "請多指教。",
      "ko": "잘 부탁드립니다.",
      "es": "Será un placer trabajar contigo.",
      "fr": "Ravi de travailler avec vous.",
      "de": "Ich freue mich auf die Zusammenarbeit.",
      "vi": "Rất mong được hợp tác với bạn.",
      "id": "Senang bisa bekerja sama dengan Anda."
    }
  },
  {
    "id": "trial_greeting_008",
    "scene": "trial",
    "subScene": "greeting",
    "level": "advanced",
    "tags": [
      "greeting"
    ],
    "translations": {
      "ja": "ご無沙汰しております。",
      "en": "I haven't been in touch for so long.",
      "zh": "好久没有联系了。",
      "zh_TW": "好久沒有聯絡了。",
      "ko": "오랫동안 연락을 못 드렸습니다.",
      "es": "Hace mucho que no estamos en contacto.",
      "fr": "Cela fait longtemps que nous n'avons pas eu de contact.",
      "de": "Wir hatten lange keinen Kontakt mehr.",
      "vi": "Lâu lắm rồi chúng ta chưa liên lạc.",
      "id": "Sudah lama kita tidak berhubungan."
    }
  },
  {
