[
  {
    "id": "trial_greeting_001",
    "scene": "trial",
    "subScene": "greeting",
    "level": "starter",
    "tags": [
      "greeting"
    ],
    "translations": {
      "ja": "はじめまして。",
      "en": "Nice to meet you.",
      "zh": "很高兴见到你。",
      "zh_TW": "很高興見到你。",
      "ko": "만나서 반갑습니다.",
      "es": "Mucho gusto.",
      "fr": "Enchanté.",
      "de": "Freut mich, dich kennenzulernen.",
      "vi": "Rất vui được gặp bạn.",
      "id": "Senang bertemu denganmu."
    }
  },
  {
    "id": "trial_greeting_002",
    "scene": "trial",
    "subScene": "greeting",
    "level": "beginner",
    "tags": [
      "greeting"
    ],
    "translations": {
      "ja": "調子はどうですか？",
      "en": "How are you?",
      "zh": "你好吗？",
      "zh_TW": "你好嗎？",
      "ko": "어떻게 지내세요?",
      "es": "¿Cómo estás?",
      "fr": "Comment ça va?",
      "de": "Wie geht es dir?",
      "vi": "Bạn khỏe không?",
      "id": "Apa kabar?"
    }
  },
  {
    "id": "trial_greeting_003",
    "scene": "trial",
    "subScene": "greeting",
    "level": "starter",
    "tags": [
      "greeting"
    ],
    "translations": {
      "ja": "またね。",
      "en": "See you later.",
      "zh": "再见。",
      "zh_TW": "待會見。",
      "ko": "나중에 봐요.",
      "es": "Hasta luego.",
      "fr": "À plus tard.",
      "de": "Bis später.",
      "vi": "Hẹn gặp lại.",
      "id": "Sampai jumpa."
    }
  },
  {
