    "scene": "trial",
    "subScene": "aizuchi",
    "level": "starter",
    "tags": [
      "aizuchi"
    ],
    "translations": {
      "ja": "本当ですか。",
      "en": "Is that true?",
      "zh": "真的吗？",
      "zh_TW": "真的嗎？",
      "ko": "정말인가요?",
      "es": "¿Es eso cierto?",
      "fr": "Est-ce vrai ?",
      "de": "Ist das wahr?",
      "vi": "Có thật không?",
      "id": "Apakah itu benar?"
    }
  },
