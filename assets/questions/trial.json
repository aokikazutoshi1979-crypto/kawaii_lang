    ],
    "translations": {
      "ja": "いいね！",
      "en": "Nice!",
      "zh": "太棒了！",
      "zh_TW": "太棒了！",
      "ko": "좋아요!",
      "es": "¡Genial!",
      "fr": "Super !",
      "de": "Schön!",
      "vi": "Tuyệt!",
      "id": "Bagus!"
    }
  },
  {
    "id": "trial_thanks_sorry_001",
    "scene": "trial",
    "subScene": "thanks_sorry",
    "level": "starter",
    "tags": [
      "thanks_sorry"
    ],
    "translations": {
      "ja": "どうもありがとう。",
      "en": "Thank you very much.",
      "zh": "非常感谢。",
      "zh_TW": "非常感謝。",
      "ko": "정말 감사합니다.",
      "es": "Muchas gracias.",
      "fr": "Merci beaucoup.",
      "de": "Vielen Dank.",
      "vi": "Cảm ơn rất nhiều.",
      "id": "Terima kasih banyak."
    }
  },
  {
    "id": "trial_thanks_sorry_002",
    "scene": "trial",
    "subScene": "thanks_sorry",
    "level": "beginner",
    "tags": [
      "thanks_sorry"
    ],
    "translations": {
      "ja": "本当に感謝しています",
      "en": "I really appreciate it.",
      "zh": "我真的很感激。",
      "zh_TW": "我真的很感激。",
      "ko": "정말 감사해요.",
      "es": "Se lo agradezco mucho.",
      "fr": "Je vous suis vraiment reconnaissant(e).",
      "de": "Ich weiß das wirklich zu schätzen.",
      "vi": "Tôi thực sự trân trọng điều đó.",
      "id": "Saya sangat menghargainya."
    }
  },
  {
    "id": "trial_thanks_sorry_003",
    "scene": "trial",
    "subScene": "thanks_sorry",
    "level": "starter",
    "tags": [
      "thanks_sorry"
    ],
    "translations": {
      "ja": "ごめんなさい。",
      "en": "I'm sorry.",
      "zh": "对不起。",
      "zh_TW": "對不起。",
      "ko": "죄송합니다.",
      "es": "Lo siento.",
      "fr": "Je suis désolé(e).",
      "de": "Es tut mir leid.",
      "vi": "Tôi xin lỗi.",
      "id": "Maaf."
    }
  },
  {
    "id": "trial_phrases_001",
    "scene": "trial",
    "subScene": "phrases",
    "level": "beginner",
    "tags": [
      "phrases"
    ],
    "translations": {
      "ja": "すみません、トイレはどこですか？",
      "en": "Excuse me, where is the bathroom?",
      "zh": "请问，洗手间在哪里？",
      "zh_TW": "請問，洗手間在哪裡？",
      "ko": "실례합니다, 화장실이 어디에 있나요?",
      "es": "Disculpe, ¿dónde está el baño?",
      "fr": "Excusez-moi, où sont les toilettes ?",
      "de": "Entschuldigung, wo ist die Toilette?",
      "vi": "Xin hỏi, nhà vệ sinh ở đâu?",
      "id": "Permisi, di mana kamar mandi?"
    }
  },
  {
    "id": "trial_phrases_002",
    "scene": "trial",
    "subScene": "phrases",
    "level": "beginner",
    "tags": [
      "phrases"
    ],
    "translations": {
      "ja": "分かりません。",
      "en": "I don't understand.",
      "zh": "我不明白。",
      "zh_TW": "我不明白。",
      "ko": "잘 모르겠습니다.",
      "es": "No entiendo.",
      "fr": "Je ne comprends pas.",
      "de": "Ich verstehe nicht.",
      "vi": "Tôi không hiểu.",
      "id": "Saya tidak mengerti."
    }
  },
  {
