    "scene": "trial",
    "subScene": "aizuchi",
    "level": "starter",
    "tags": [
      "aizuchi"
    ],
    "translations": {
      "ja": "なるほど。",
      "en": "I see.",
      "zh": "原来如此。",
      "zh_TW": "原來如此。",
      "ko": "그렇군요.",
      "es": "Ya veo.",
      "fr": "Je vois.",
      "de": "Ach so.",
      "vi": "Ra là vậy.",
      "id": "Oh, begitu."
    }
  },
  {
    "id": "trial_aizuchi_005",
    "scene": "trial",
    "subScene": "aizuchi",
    "level": "intermediate",
    "tags": [
      "aizuchi"
    ],
    "translations": {
      "ja": "それは知らなかった！",
      "en": "I didn't know that!",
      "zh": "这个我不知道！",
      "zh_TW": "這我不知道！",
      "ko": "그건 몰랐어요!",
      "es": "¡No sabía eso!",
      "fr": "Je ne savais pas !",
      "de": "Das wusste ich nicht!",
      "vi": "Tôi không biết điều đó!",
      "id": "Saya tidak tahu itu!"
    }
  },
  {
    "id": "trial_aizuchi_006",
    "scene": "trial",
    "subScene": "aizuchi",
    "level": "intermediate",
    "tags": [
      "aizuchi"
    ],
    "translations": {
      "ja": "確かにそうですね。",
      "en": "You're right about that.",
      "zh": "确实如此。",
      "zh_TW": "的確如此。",
      "ko": "정말 그렇네요.",
      "es": "Tienes razón.",
      "fr": "C'est vrai.",
      "de": "Da hast du recht.",
      "vi": "Đúng là như vậy.",
      "id": "Memang benar begitu."
    }
  },
  {
    "id": "trial_phrases_004",
    "scene": "trial",
    "subScene": "phrases",
    "level": "beginner",
    "tags": [
      "phrases"
    ],
    "translations": {
      "ja": "少し待ってください。",
      "en": "Please wait a moment.",
      "zh": "请稍等一下。",
      "zh_TW": "請稍等一下。",
      "ko": "잠시만 기다려 주세요.",
      "es": "Espere un momento, por favor.",
      "fr": "Veuillez patienter un moment, s'il vous plaît.",
      "de": "Bitte warten Sie einen Moment.",
      "vi": "Vui lòng chờ một chút.",
      "id": "Mohon tunggu sebentar."
    }
  },
  {
    "id": "trial_phrases_005",
    "scene": "trial",
    "subScene": "phrases",
    "level": "intermediate",
    "tags": [
      "phrases"
    ],
    "translations": {
      "ja": "もう一度言ってもらえますか？",
      "en": "Could you say that again?",
      "zh": "可以再说一遍吗？",
      "zh_TW": "可以再說一次嗎？",
      "ko": "한 번 더 말씀해 주시겠어요?",
      "es": "¿Podría decirlo otra vez?",
      "fr": "Pourriez-vous le répéter ?",
      "de": "Könnten Sie das bitte noch einmal sagen?",
      "vi": "Bạn có thể nói lại được không?",
      "id": "Bisakah Anda mengatakannya sekali lagi?"
    }
  },
  {
    "id": "trial_phrases_006",
    "scene": "trial",
    "subScene": "phrases",
    "level": "intermediate",
    "tags": [
      "phrases"
    ],
    "translations": {
      "ja": "ゆっくり話してもらえますか？",
      "en": "Could you speak more slowly?",
      "zh": "可以说慢一点吗？",
      "zh_TW": "可以說慢一點嗎？",
      "ko": "좀 더 천천히 말씀해 주시겠어요?",
      "es": "¿Podría hablar más despacio?",
      "fr": "Pourriez-vous parler plus lentement ?",
      "de": "Könnten Sie bitte langsamer sprechen?",
      "vi": "Bạn có thể nói chậm hơn được không?",
      "id": "Bisakah Anda berbicara lebih pelan?"
    }
  },
  {
    "id": "trial_phrases_007",
    "scene": "trial",
    "subScene": "phrases",
    "level": "advanced",
    "tags": [
      "phrases"
    ],
    "translations": {
      "ja": "差し支えなければ、教えていただけますか？",
      "en": "If you don't mind, could you tell me?",
      "zh": "如果方便的话，可以告诉我吗？",
      "zh_TW": "如果方便的話，可以告訴我嗎？",
      "ko": "괜찮으시다면 알려 주실 수 있을까요?",
      "es": "Si no le importa, ¿podría decírmelo?",
      "fr": "Si cela ne vous dérange pas, pourriez-vous me le dire ?",
      "de": "Wenn es Ihnen nichts ausmacht, könnten Sie es mir sagen?",
      "vi": "Nếu bạn không phiền, bạn có thể cho tôi biết được không?",
      "id": "Jika Anda tidak keberatan, bisakah Anda memberi tahu saya?"
    }
  }
]
