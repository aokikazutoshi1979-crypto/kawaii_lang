    "tags": [
      "greeting"
    ],
    "translations": {
      "ja": "おはようございます。",
      "en": "Good morning.",
      "zh": "早上好。",
      "zh_TW": "早安。",
      "ko": "좋은 아침입니다.",
      "es": "Buenos días.",
      "fr": "Bonjour.",
      "de": "Guten Morgen.",
      "vi": "Chào buổi sáng.",
      "id": "Selamat pagi."
    }
  },
  {
